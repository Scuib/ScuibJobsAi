# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Phase 2: Supabase (leave blank to use InMemoryStore) ──────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Phase 2: Handoff endpoint (leave blank to write to file) ──────────────────
HANDOFF_ENDPOINT_URL=
HANDOFF_API_KEY=
HANDOFF_FILE_PATH=handoff_output.jsonl  # used when HANDOFF_ENDPOINT_URL is not set

# ── Ingestion config ──────────────────────────────────────────────────────────
# Queries and Locations (comma-separated lists)
INGEST_QUERIES=software engineer,backend developer,python developer
INGEST_LOCATIONS=remote,United States
TARGET_JOB_COUNT=200

# JSearch API (RapidAPI)
JSEARCH_API_KEY=
JSEARCH_PAGES=10

# Adzuna API (Free Tier: 250 calls/day)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_PAGES=5

# Recency Filter: today | 3days | week | month
DATE_POSTED_FILTER=week

# ── Parser config ─────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash   # swap to gemini-1.5-pro for higher accuracy
AUTO_APPROVE_CONFIDENCE_THRESHOLD=0.9  # leave blank or set to auto-approve high confidence jobs

# ── Concurrency & Resilience ──────────────────────────────────────────────────
MAX_CONCURRENT_PARSES=15
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN=60
RATE_LIMIT_REQUESTS_PER_MINUTE=60
