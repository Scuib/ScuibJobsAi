# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Phase 2: Supabase (leave blank to use InMemoryStore) ──────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Phase 2: Handoff endpoint (leave blank to write to file) ──────────────────
HANDOFF_ENDPOINT_URL=
HANDOFF_API_KEY=
HANDOFF_FILE_PATH=handoff_output.jsonl  # used when HANDOFF_ENDPOINT_URL is not set

# ── Ingestion config ──────────────────────────────────────────────────────────
INGEST_QUERY=software engineer
INGEST_LOCATION=remote
JSEARCH_API_KEY=

# ── Parser config ─────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-flash   # swap to gemini-1.5-pro for higher accuracy

# ── Concurrency ───────────────────────────────────────────────────────────────
MAX_CONCURRENT_PARSES=5
